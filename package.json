{
  "name": "allen-kenoyer-redesign",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": ">=11.1.3 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "check:e2e": "pnpm check && pnpm test:e2e",
    "migrate:images": "node --env-file=.env.local scripts/migrate-images.mjs",
    "migrate:patterns": "node --env-file=.env.local scripts/migrate-pattern-images.mjs",
    "gen:tracker": "node scripts/gen-tracker.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  }
}
