# Environment variables for the Allen Kenoyer Glass rebuild.
#
# Copy this file to `.env.local` and fill in values for local development.
# `.env.local` is git-ignored — never commit it.

# --- Supabase ---
# Project URL and publishable (client-safe) API key. Both are safe to ship
# to the browser via NEXT_PUBLIC_ exposure. Find them in the Supabase
# dashboard under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret key (sb_secret_...). The modern server-side counterpart to the
# publishable key — replaces the legacy service_role JWT and adds extra
# misuse protections (e.g., Supabase rejects it server-side if it ever
# arrives with a browser User-Agent). Used only by server-side scripts
# (e.g., the image migration script in /scripts). Never prefix with
# NEXT_PUBLIC_, never commit to git. Find it under Project Settings → API.
SUPABASE_SECRET_KEY=
